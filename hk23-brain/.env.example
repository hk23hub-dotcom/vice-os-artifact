# Aria — live connection to your Supabase (hk23 schema). Copy to .env and fill in. Never commit real keys.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_KEY=YOUR-SERVICE-OR-ANON-KEY      # needs read on hk23.entities; write on hk23.relationships for --write

# Optional: smarter, semantic reflections via your GPT (otherwise Aria runs offline/word-overlap)
OPENAI_API_KEY=
HK23_MODEL=gpt-4.1
